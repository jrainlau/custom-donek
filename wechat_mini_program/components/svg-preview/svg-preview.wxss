.svg-preview-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  width: 50%;
}

/* 旋转模式下宽度占满 */
.svg-preview-container.rotated {
  width: 100%;
}

.label {
  font-size: 22rpx;
  font-weight: 500;
  color: var(--md-sys-color-on-surface-variant);
  letter-spacing: 1rpx;
}

/* 普通模式 */
.svg-wrapper {
  width: 100%;
  display: flex;
  justify-content: center;
  align-items: center;
  overflow: hidden;
}

.svg-image {
  width: 100%;
  height: 400rpx;
}

/* 旋转模式 - 外层容器 */
/* SVG 原始比例 930:4290 ≈ 0.217，旋转90°后视觉宽高比 = 4290:930 ≈ 4.613:1 */
/* 容器宽度约 702rpx(750-48rpx padding)，旋转后视觉高度 = 702/4.613 ≈ 152rpx */
.svg-rotate-wrapper {
  width: 100%;
  height: 152rpx;
  position: relative;
  display: flex;
  justify-content: center;
  align-items: center;
}

/* 旋转模式 - 图片 */
/* image 先竖直放置（旋转前 width 小、height 大），然后 CSS 旋转90° */
/* 旋转后视觉宽度 = 旋转前 height，视觉高度 = 旋转前 width */
/* 要让旋转后刚好填满容器：
     旋转前 height ≈ 容器宽度 = 702rpx
     旋转前 width  ≈ 容器高度 = 152rpx
*/
.svg-image-rotated {
  width: 152rpx;
  height: 702rpx;
  transform-origin: center center;
}
