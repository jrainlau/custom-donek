.user-schemes {
  width: 100%;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
  border-bottom: 1rpx solid var(--md-sys-color-outline-variant);
  padding-bottom: 16rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 500;
  color: var(--md-sys-color-on-surface);
}

.save-btn {
  padding: 16rpx 40rpx;
  border-radius: 40rpx;
  background: var(--md-sys-color-secondary-container);
  color: var(--md-sys-color-on-secondary-container);
  font-size: 28rpx;
  font-weight: 500;
  box-shadow: var(--md-sys-elevation-level1);
}

.empty-tip {
  text-align: center;
  color: var(--md-sys-color-on-surface-variant);
  font-size: 28rpx;
  padding: 40rpx 0;
}

.schemes-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.scheme-item {
  width: calc(50% - 10rpx);
  padding: 24rpx;
  border-radius: var(--md-sys-shape-corner-medium);
  background: var(--md-sys-color-surface-container-low);
  border: none;
  outline: 2rpx solid var(--md-sys-color-outline-variant);
  outline-offset: 0;
  position: relative;
  transition: all 0.2s;
}

.scheme-item.active {
  background: var(--md-sys-color-surface-container);
  outline: 4rpx solid var(--md-sys-color-primary);
  outline-offset: 4rpx;
  box-shadow: 0 0 24rpx 4rpx rgba(103, 80, 164, 0.45);
}

.delete-btn {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: var(--md-sys-color-surface-container-highest);
  color: var(--md-sys-color-on-surface-variant);
  font-size: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
}

.scheme-colors {
  display: flex;
  justify-content: center;
  gap: 8rpx;
}

.color-dot {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
}
