.preset-templates {
  width: 100%;
}

.section-title {
  display: block;
  font-size: 32rpx;
  font-weight: 500;
  color: var(--md-sys-color-on-surface);
  margin-bottom: 24rpx;
  border-bottom: 1rpx solid var(--md-sys-color-outline-variant);
  padding-bottom: 16rpx;
}

.preset-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 24rpx;
}

.preset-item {
  width: calc(50% - 12rpx);
  padding: 24rpx;
  border-radius: var(--md-sys-shape-corner-medium);
  background: var(--md-sys-color-surface-container-low);
  border: none;
  outline: 2rpx solid var(--md-sys-color-outline-variant);
  outline-offset: 0;
  transition: all 0.2s;
}

.preset-item.active {
  background: var(--md-sys-color-surface-container);
  outline: 4rpx solid var(--md-sys-color-primary);
  outline-offset: 4rpx;
  box-shadow: 0 0 24rpx 4rpx rgba(103, 80, 164, 0.45);
}

.preset-colors {
  display: flex;
  justify-content: center;
  gap: 12rpx;
}

.color-dot {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
}
