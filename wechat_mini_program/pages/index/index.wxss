.page-container {
  min-height: 100vh;
  background: var(--md-sys-color-surface);
}

/* ========== 自定义导航栏 ========== */
.custom-navbar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: var(--md-sys-color-surface);
  box-shadow: var(--md-sys-elevation-level2);
}

.navbar-content {
  display: flex;
  align-items: center;
  justify-content: flex-start;
  padding: 0 32rpx;
}

.navbar-title-area {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 16rpx;
}

.navbar-title-text {
  display: flex;
  flex-direction: column;
}

.navbar-title {
  font-size: 36rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
  color: var(--md-sys-color-primary);
  line-height: 1.2;
}

.navbar-subtitle {
  font-size: 22rpx;
  color: var(--md-sys-color-on-surface-variant);
  margin-top: 2rpx;
}

.export-btn {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: var(--md-sys-color-primary);
  color: var(--md-sys-color-on-primary);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  box-shadow: var(--md-sys-elevation-level1);
  transition: all 0.2s;
}

.export-btn.disabled {
  background: var(--md-sys-color-surface-container-highest);
  color: var(--md-sys-color-on-surface-variant);
}

/* ========== SVG 预览区（fixed 在导航栏下方） ========== */
.snapshot-area {
  background-color: #e0e0e0;
  background-image:
    linear-gradient(45deg, #c0c0c0 25%, transparent 25%, transparent 75%, #c0c0c0 75%),
    linear-gradient(45deg, #c0c0c0 25%, transparent 25%, transparent 75%, #c0c0c0 75%);
  background-size: 30rpx 30rpx;
  background-position: 0 0, 15rpx 15rpx;
}

.preview-section {
  position: fixed;
  left: 0;
  right: 0;
  z-index: 90;
  background-color: #aaa9a9;
  background-image:
    linear-gradient(45deg, #c0c0c0 25%, transparent 25%, transparent 75%, #c0c0c0 75%),
    linear-gradient(45deg, #c0c0c0 25%, transparent 25%, transparent 75%, #c0c0c0 75%);
  background-size: 80rpx 80rpx;
  background-position: 0 0, 40rpx 40rpx;
  padding: 16rpx 24rpx;
  box-shadow: var(--md-sys-elevation-level2);
  overflow: hidden;
}

.snapshot-title {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 0 8rpx;
}

.snapshot-title-main {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--md-sys-color-primary);
  letter-spacing: 2rpx;
}

.snapshot-title-sub {
  font-size: 20rpx;
  color: var(--md-sys-color-on-surface-variant);
  margin-top: 4rpx;
}

.preview-column {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  justify-content: center;
  align-items: center;
}

/* ========== 功能区 ========== */
.content-area {
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.card {
  background: var(--md-sys-color-surface-container-low);
  border-radius: var(--md-sys-shape-corner-large);
  padding: 32rpx;
  box-shadow: var(--md-sys-elevation-level1);
}

/* ========== 截图配色信息 ========== */
.snapshot-colors {
  display: flex;
  justify-content: space-around;
  padding: 16rpx 0 8rpx;
  gap: 8rpx;
}

.snapshot-color-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.snapshot-color-dot {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(0, 0, 0, 0.1);
}

.snapshot-color-info {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.snapshot-color-label {
  font-size: 20rpx;
  font-weight: 500;
  color: var(--md-sys-color-on-surface);
}

.snapshot-color-rgb {
  font-size: 18rpx;
  font-family: monospace;
  color: var(--md-sys-color-on-surface-variant);
}
