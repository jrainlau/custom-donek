<view class="page-container">
  <!-- ========== 自定义导航栏 ========== -->
  <view class="custom-navbar" style="padding-top: {{statusBarHeight}}px; height: {{navBarHeight}}px;">
    <view class="navbar-content" style="height: {{navBarHeight - statusBarHeight}}px;">
      <view class="navbar-title-area">
        <view class="navbar-title-text">
          <text class="navbar-title">DONEK</text>
          <text class="navbar-subtitle">滑雪板配色定制</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 导航栏占位 -->
  <view style="height: {{navBarHeight}}px;"></view>

  <!-- ========== SVG 预览区（fixed 在导航栏下方） ========== -->
  <view class="preview-section" style="top: {{navBarHeight}}px;">
      <view class="snapshot-title">
        <text class="snapshot-title-main">  </text>
      </view>
    <view class="preview-column">
      <svg-preview
        svgRaw="{{topsheetSvg}}"
        primaryColor="{{topPrimary}}"
        secondaryColor="{{topSecondary}}"
        primaryClass="color-primary"
        secondaryClass="color-secondary"
        rotation="{{-90}}"
      />
      <svg-preview
        svgRaw="{{baseSvg}}"
        primaryColor="{{basePattern}}"
        secondaryColor="{{baseBg}}"
        primaryClass="color-pattern"
        secondaryClass="color-bg"
        rotation="{{90}}"
      />
    </view>
      <!-- 截图中展示的配色信息 -->
      <view class="snapshot-colors">
        <view class="snapshot-color-item" wx:for="{{snapshotColors}}" wx:key="index">
          <view class="snapshot-color-dot" style="background-color: {{item.hex}};"></view>
          <view class="snapshot-color-info">
            <text class="snapshot-color-label">{{item.label}}</text>
            <text class="snapshot-color-rgb">{{item.rgb}}</text>
          </view>
        </view>
      </view>
  </view>

  <!-- 预览区占位（预览区 fixed 后需要占位避免内容被遮挡，额外加 16px 间距） -->
  <view style="height: {{previewHeight + 16}}px;"></view>

  <!-- ========== 功能区 ========== -->
  <view class="content-area">
    <!-- 颜色配置面板 -->
    <view class="card">
      <color-panel
        topPrimary="{{topPrimary}}"
        topSecondary="{{topSecondary}}"
        basePattern="{{basePattern}}"
        baseBg="{{baseBg}}"
        seedColor="{{seedColor}}"
        showSeedPicker="{{showSeedPicker}}"
        error="{{seedError}}"
        bindcolorchange="onColorChange"
        bindswapcolors="onSwapColors"
        bindtoggleseedpicker="onToggleSeedPicker"
        bindseedcolorchange="onSeedColorChange"
        bindgenerate="onGenerate"
      />
      <!-- 保存当前配色按钮 -->
      <view class="save-scheme-btn" bindtap="onSaveScheme">保存当前配色</view>
    </view>

    <!-- 配色方案（预设 + 我的 TAB 合并卡片） -->
    <view class="card">
      <!-- TAB 栏 -->
      <view class="color-tab-bar">
        <view class="color-tab-item {{colorTab === 'preset' ? 'active' : ''}}" bindtap="onSwitchTab" data-tab="preset">
          <text>🎯 预设配色</text>
        </view>
        <view class="color-tab-item {{colorTab === 'user' ? 'active' : ''}}" bindtap="onSwitchTab" data-tab="user">
          <text>💾 我的配色{{userSchemesCount > 0 ? ' (' + userSchemesCount + ')' : ''}}</text>
        </view>
      </view>

      <!-- TAB 内容 -->
      <view wx:if="{{colorTab === 'preset'}}">
        <preset-templates
          activeSchemeId="{{activeSchemeId}}"
          bindselect="onPresetSelect"
        />
      </view>
      <view wx:if="{{colorTab === 'user'}}">
        <user-schemes
          topPrimary="{{topPrimary}}"
          topSecondary="{{topSecondary}}"
          basePattern="{{basePattern}}"
          baseBg="{{baseBg}}"
          activeSchemeId="{{activeSchemeId}}"
          saveTrigger="{{saveTrigger}}"
          bindselect="onUserSchemeSelect"
          bindschemescountchange="onSchemesCountChange"
        />
      </view>
    </view>
  </view>


</view>
