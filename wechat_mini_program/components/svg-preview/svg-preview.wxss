.svg-preview-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  width: 50%;
}

.label {
  font-size: 22rpx;
  font-weight: 500;
  color: var(--md-sys-color-on-surface-variant);
  letter-spacing: 1rpx;
}

.svg-wrapper {
  width: 100%;
  display: flex;
  justify-content: center;
  align-items: center;
  overflow: hidden;
}

.svg-image {
  width: 100%;
  height: 400rpx;
}
