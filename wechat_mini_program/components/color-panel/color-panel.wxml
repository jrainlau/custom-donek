<view class="color-panel">
  <!-- 标题栏 + 种子颜色 + 智能配色按钮 -->
  <view class="panel-header">
    <text class="panel-title">🎨 颜色配置</text>
    <view class="header-actions">
      <!-- 种子颜色色块 -->
      <view
        class="seed-color-block {{showSeedPicker ? 'active' : ''}}"
        style="background-color: {{seedColor}};"
        bindtap="onToggleSeedPicker"
      />
      <!-- 智能配色按钮 -->
      <view class="generate-btn" bindtap="onGenerate">智能配色</view>
    </view>
  </view>

  <!-- 种子颜色拾色器 -->
  <view class="seed-picker-wrapper" wx:if="{{showSeedPicker}}">
    <color-picker
      color="{{seedColor}}"
      bindcolorchange="onSeedColorChange"
    />
  </view>

  <!-- 错误提示 -->
  <view class="error-tip" wx:if="{{error}}">
    <text>⚠️ {{error}}</text>
  </view>

  <!-- 拖拽提示 -->
  <view class="drag-tip">
    <text>💡 长按色块可交换颜色</text>
  </view>

  <!-- 2×2 色块网格 -->
  <view class="color-grid">
    <view
      wx:for="{{colorItems}}"
      wx:key="index"
      class="color-slot"
      style="background-color: {{item.color}};"
      data-index="{{item.index}}"
      bindlongpress="onLongPress"
    >
      <!-- 标签 -->
      <text class="slot-label" style="color: {{item.textColor}};">{{item.label}}</text>

      <!-- 拖拽提示图标 -->
      <text class="slot-drag-icon" style="color: {{item.textColor}};">⠿</text>

      <!-- 底部：RGB 值 + 修改按钮 -->
      <view class="slot-bottom">
        <view
          class="slot-rgb"
          data-index="{{item.index}}"
          catchtap="onCopyColor"
        >
          <text style="color: {{item.textColor}};">{{copiedIndex === item.index ? '✅ 已复制' : item.rgbString}}</text>
        </view>
        <view
          class="slot-edit-btn"
          data-index="{{item.index}}"
          catchtap="onOpenEditor"
        >
          <text style="color: {{item.textColor}};">✏️</text>
        </view>
      </view>
    </view>
  </view>

  <!-- ===== 颜色编辑弹窗 ===== -->
  <view class="modal-overlay" wx:if="{{editingIndex >= 0}}" catchtap="onOverlayTap">
    <view class="modal-card" catchtap="onModalCardTap">
      <!-- 弹窗头部 -->
      <view class="modal-header">
        <text class="modal-title">🎨 {{editingItem.label}}</text>
        <view class="modal-close" catchtap="onCloseEditor">
          <text>×</text>
        </view>
      </view>

      <!-- 当前颜色预览条 -->
      <view class="modal-color-preview" style="background-color: {{editingItem.color}};"></view>

      <!-- 拾色器 -->
      <color-picker
        color="{{editingItem.color}}"
        bindcolorchange="onEditorPickerChange"
      />

      <!-- RGB 滑块 -->
      <view class="rgb-sliders">
        <view class="slider-row">
          <text class="channel-label" style="color: #e74c3c;">R</text>
          <slider
            min="0"
            max="255"
            value="{{editingItem.r}}"
            activeColor="#e74c3c"
            block-size="16"
            data-channel="r"
            bindchange="onEditorSliderChange"
            bindchanging="onEditorSliderChanging"
          />
          <text class="channel-value">{{editingItem.r}}</text>
        </view>
        <view class="slider-row">
          <text class="channel-label" style="color: #27ae60;">G</text>
          <slider
            min="0"
            max="255"
            value="{{editingItem.g}}"
            activeColor="#27ae60"
            block-size="16"
            data-channel="g"
            bindchange="onEditorSliderChange"
            bindchanging="onEditorSliderChanging"
          />
          <text class="channel-value">{{editingItem.g}}</text>
        </view>
        <view class="slider-row">
          <text class="channel-label" style="color: #2980b9;">B</text>
          <slider
            min="0"
            max="255"
            value="{{editingItem.b}}"
            activeColor="#2980b9"
            block-size="16"
            data-channel="b"
            bindchange="onEditorSliderChange"
            bindchanging="onEditorSliderChanging"
          />
          <text class="channel-value">{{editingItem.b}}</text>
        </view>
      </view>

      <!-- 剪贴板 RGB 快捷应用 -->
      <view class="clipboard-rgb-btn" wx:if="{{clipboardRgb}}" catchtap="onApplyClipboardRgb" style="background-color: {{clipboardRgbHex}};">
        <text class="clipboard-rgb-btn-text" style="color: {{clipboardRgbTextColor}};">📋 使用 {{clipboardRgb}} 颜色</text>
      </view>

    </view>
  </view>
</view>
