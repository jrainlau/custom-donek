.color-panel {
  width: 100%;
}

/* 标题栏 */
.panel-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
  border-bottom: 1rpx solid var(--md-sys-color-outline-variant);
  padding-bottom: 16rpx;
  flex-wrap: wrap;
  gap: 16rpx;
}

.panel-title {
  font-size: 32rpx;
  font-weight: 500;
  color: var(--md-sys-color-on-surface);
}

.header-actions {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.seed-color-block {
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
  border: 2rpx solid var(--md-sys-color-outline);
  transition: all 0.2s;
}

.seed-color-block.active {
  border-color: var(--md-sys-color-primary);
  box-shadow: 0 0 0 4rpx var(--md-sys-color-primary-container);
}

.generate-btn {
  padding: 12rpx 32rpx;
  border-radius: 32rpx;
  background: var(--md-sys-color-secondary-container);
  color: var(--md-sys-color-on-secondary-container);
  font-size: 24rpx;
  font-weight: 500;
  box-shadow: var(--md-sys-elevation-level1);
}

/* 种子颜色拾色器 */
.seed-picker-wrapper {
  margin-bottom: 24rpx;
}

/* 错误提示 */
.error-tip {
  padding: 16rpx 24rpx;
  border-radius: var(--md-sys-shape-corner-small);
  background-color: var(--md-sys-color-error-container);
  color: var(--md-sys-color-on-error-container);
  font-size: 24rpx;
  margin-bottom: 24rpx;
}

/* 拖拽提示 */
.drag-tip {
  font-size: 24rpx;
  color: var(--md-sys-color-on-surface-variant);
  margin-bottom: 16rpx;
}

/* 2×2 色块网格 */
.color-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.color-slot {
  width: calc(50% - 8rpx);
  box-sizing: border-box;
  border-radius: var(--md-sys-shape-corner-medium);
  padding: 20rpx 16rpx;
  border: 2rpx solid var(--md-sys-color-outline-variant);
  position: relative;
  min-height: 136rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  overflow: hidden;
}

.slot-label {
  font-size: 24rpx;
  font-weight: 700;
  opacity: 0.9;
  margin-bottom: 8rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.slot-drag-icon {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  font-size: 28rpx;
  opacity: 0.5;
}

.slot-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 8rpx;
  min-width: 0;
}

.slot-rgb {
  font-size: 20rpx;
  font-family: monospace;
  opacity: 0.8;
  padding: 4rpx 8rpx;
  border-radius: 8rpx;
  background-color: rgba(0, 0, 0, 0.08);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  min-width: 0;
  flex: 1;
}

.slot-edit-btn {
  font-size: 22rpx;
  font-weight: 600;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  background-color: rgba(0, 0, 0, 0.12);
  flex-shrink: 0;
}

/* 弹窗遮罩层 */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: flex-start;
  justify-content: center;
  padding-top: 15vh;
}

/* 弹窗卡片 */
.modal-card {
  width: 620rpx;
  max-height: 70vh;
  background: var(--md-sys-color-surface);
  border-radius: 56rpx;
  padding: 48rpx;
  box-shadow: var(--md-sys-elevation-level3);
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 500;
  color: var(--md-sys-color-on-surface);
}

.modal-close {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  font-size: 40rpx;
  color: var(--md-sys-color-on-surface-variant);
}

.modal-color-preview {
  height: 80rpx;
  border-radius: var(--md-sys-shape-corner-medium);
  margin-bottom: 32rpx;
  border: 2rpx solid var(--md-sys-color-outline-variant);
}



.rgb-sliders {
  margin-top: 16rpx;
}

.slider-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 6rpx;
}

.channel-label {
  font-size: 22rpx;
  font-weight: 700;
  width: 28rpx;
  text-align: center;
}

.slider-row slider {
  flex: 1;
}

.channel-value {
  font-size: 22rpx;
  font-family: monospace;
  width: 56rpx;
  text-align: right;
  color: var(--md-sys-color-on-surface);
}

/* 剪贴板 RGB 快捷应用按钮 */
.clipboard-rgb-btn {
  margin-top: 24rpx;
  padding: 20rpx 32rpx;
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: var(--md-sys-elevation-level1);
  border: 2rpx solid var(--md-sys-color-outline-variant);
  transition: all 0.2s;
}

.clipboard-rgb-btn:active {
  opacity: 0.8;
  transform: scale(0.98);
}

.clipboard-rgb-btn-text {
  font-size: 26rpx;
  font-weight: 500;
  font-family: monospace;
}
