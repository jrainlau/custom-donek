/* ============================================
   Material Design 3 — Design Tokens (小程序版)
   ============================================ */

page {
  /* ---------- M3 Color Tokens (Light Theme) ---------- */
  --md-sys-color-primary: #6750A4;
  --md-sys-color-on-primary: #FFFFFF;
  --md-sys-color-primary-container: #EADDFF;
  --md-sys-color-on-primary-container: #21005D;

  --md-sys-color-secondary: #625B71;
  --md-sys-color-on-secondary: #FFFFFF;
  --md-sys-color-secondary-container: #E8DEF8;
  --md-sys-color-on-secondary-container: #1D192B;

  --md-sys-color-tertiary: #7D5260;
  --md-sys-color-on-tertiary: #FFFFFF;
  --md-sys-color-tertiary-container: #FFD8E4;
  --md-sys-color-on-tertiary-container: #31111D;

  --md-sys-color-error: #B3261E;
  --md-sys-color-on-error: #FFFFFF;
  --md-sys-color-error-container: #F9DEDC;
  --md-sys-color-on-error-container: #410E0B;

  --md-sys-color-surface: #FEF7FF;
  --md-sys-color-on-surface: #1D1B20;
  --md-sys-color-surface-variant: #E7E0EC;
  --md-sys-color-on-surface-variant: #49454F;

  --md-sys-color-surface-container-lowest: #FFFFFF;
  --md-sys-color-surface-container-low: #F7F2FA;
  --md-sys-color-surface-container: #F3EDF7;
  --md-sys-color-surface-container-high: #ECE6F0;
  --md-sys-color-surface-container-highest: #E6E0E9;

  --md-sys-color-outline: #79747E;
  --md-sys-color-outline-variant: #CAC4D0;

  --md-sys-color-inverse-surface: #322F35;
  --md-sys-color-inverse-on-surface: #F5EFF7;
  --md-sys-color-inverse-primary: #D0BCFF;

  --md-sys-color-scrim: #000000;
  --md-sys-color-shadow: #000000;

  /* ---------- M3 Shape (Corner Radius) ---------- */
  --md-sys-shape-corner-none: 0rpx;
  --md-sys-shape-corner-extra-small: 8rpx;
  --md-sys-shape-corner-small: 16rpx;
  --md-sys-shape-corner-medium: 24rpx;
  --md-sys-shape-corner-large: 32rpx;
  --md-sys-shape-corner-extra-large: 56rpx;
  --md-sys-shape-corner-full: 9999rpx;

  /* ---------- M3 Elevation (Box Shadows) ---------- */
  --md-sys-elevation-level0: none;
  --md-sys-elevation-level1: 0rpx 2rpx 4rpx rgba(0, 0, 0, 0.3), 0rpx 2rpx 6rpx 2rpx rgba(0, 0, 0, 0.15);
  --md-sys-elevation-level2: 0rpx 2rpx 4rpx rgba(0, 0, 0, 0.3), 0rpx 4rpx 12rpx 4rpx rgba(0, 0, 0, 0.15);
  --md-sys-elevation-level3: 0rpx 8rpx 16rpx 6rpx rgba(0, 0, 0, 0.15), 0rpx 2rpx 6rpx rgba(0, 0, 0, 0.3);

  /* ---------- 全局基础样式 ---------- */
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', 'PingFang SC', 'Microsoft YaHei', sans-serif;
  font-size: 28rpx;
  line-height: 1.5;
  color: var(--md-sys-color-on-surface);
  background-color: var(--md-sys-color-surface);
  box-sizing: border-box;
}

/* 全局盒模型 */
view, text, image, scroll-view, swiper {
  box-sizing: border-box;
}
